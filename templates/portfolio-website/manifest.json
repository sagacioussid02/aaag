{
  "slug": "portfolio-website",
  "version": "1.0.0",
  "display_name": "AI Portfolio Website",
  "platform": "web",
  "config_schema_version": "1",
  "consumes": {
    "meta_keys": ["app_name", "theme", "recipient_name", "buyer_email", "plan_type"],
    "user_input_keys": [
      "gift_mode",
      "recipient_context",
      "portfolio_notes",
      "tone",
      "target_roles",
      "preferred_theme",
      "selected_plan",
      "deployment_strategy"
    ],
    "media_keys": ["resume_pdf", "cover_letter_pdf"],
    "ai_content_shape": "PortfolioContent"
  },
  "deploy": {
    "target": "vercel",
    "vercel_project_id": "",
    "env_vars": ["NEXT_PUBLIC_APP_ID", "NEXT_PUBLIC_CONFIG_URL"]
  }
}
