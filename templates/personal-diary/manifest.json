{
  "slug": "personal-diary",
  "version": "1.0.0",
  "display_name": "Personal Diary",
  "platform": "web",
  "config_schema_version": "1",
  "consumes": {
    "meta_keys":       ["app_name", "theme", "recipient_name", "buyer_email", "plan_type"],
    "user_input_keys": ["personal_message"],
    "media_keys":      ["photos"],
    "ai_content_shape": "DiaryAppContent"
  },
  "deploy": {
    "target":            "vercel",
    "vercel_project_id": "",
    "env_vars":          ["NEXT_PUBLIC_APP_ID", "NEXT_PUBLIC_CONFIG_URL"]
  }
}
